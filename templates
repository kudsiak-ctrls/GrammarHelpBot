<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GrammarHelpBot – DE / EN / Roman Urdu</title>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg:        #0d0f14;
      --surface:   #161921;
      --card:      #1e2230;
      --border:    #2a2f42;
      --accent:    #5b8cff;
      --accent2:   #a78bfa;
      --green:     #34d399;
      --yellow:    #fbbf24;
      --red:       #f87171;
      --text:      #e2e8f0;
      --muted:     #64748b;
      --radius:    14px;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ── Header ── */
    header {
      width: 100%;
      padding: 28px 40px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
      border-bottom: 1px solid var(--border);
    }
    .logo {
      width: 40px; height: 40px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    header h1 { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.5px; }
    header span { font-size: 0.8rem; color: var(--muted); margin-left: 4px; }

    /* ── Lang badges ── */
    .lang-badges {
      margin-left: auto;
      display: flex; gap: 8px;
    }
    .badge {
      padding: 4px 12px;
      border-radius: 999px;
      font-size: 0.72rem;
      font-weight: 600;
      letter-spacing: 0.5px;
      border: 1px solid var(--border);
      color: var(--muted);
    }
    .badge.de { border-color: #3b82f6; color: #3b82f6; }
    .badge.en { border-color: #34d399; color: #34d399; }
    .badge.ur { border-color: #a78bfa; color: #a78bfa; }

    /* ── Main layout ── */
    main {
      width: 100%;
      max-width: 900px;
      padding: 40px 20px 60px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .tagline {
      text-align: center;
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.6;
    }
    .tagline strong { color: var(--text); }

    /* ── Input card ── */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 24px;
    }
    .card-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 12px;
    }
    textarea {
      width: 100%;
      min-height: 130px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
      font-family: 'Sora', sans-serif;
      font-size: 0.95rem;
      color: var(--text);
      resize: vertical;
      outline: none;
      transition: border-color 0.2s;
      line-height: 1.6;
    }
    textarea:focus { border-color: var(--accent); }
    textarea::placeholder { color: var(--muted); }

    .input-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 12px;
    }
    #charCount { font-size: 0.78rem; color: var(--muted); }
    #charCount.warn { color: var(--yellow); }
    #charCount.over { color: var(--red); }

    button#submitBtn {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: white;
      border: none;
      padding: 10px 28px;
      border-radius: 10px;
      font-family: 'Sora', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.1s;
    }
    button#submitBtn:hover { opacity: 0.88; transform: translateY(-1px); }
    button#submitBtn:active { transform: translateY(0); }
    button#submitBtn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    /* ── Loading ── */
    #loading {
      display: none;
      text-align: center;
      padding: 24px;
      color: var(--muted);
      font-size: 0.88rem;
    }
    .spinner {
      width: 28px; height: 28px;
      border: 3px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Result card ── */
    #result { display: none; }

    .result-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 20px;
    }
    .status-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
    }
    .status-dot.ok   { background: var(--green); box-shadow: 0 0 8px var(--green); }
    .status-dot.fixed { background: var(--accent); box-shadow: 0 0 8px var(--accent); }

    .result-title { font-size: 1rem; font-weight: 600; }
    .detected-lang {
      margin-left: auto;
      font-size: 0.75rem;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      padding: 3px 10px;
      border-radius: 999px;
    }

    /* Text comparison */
    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin-bottom: 20px;
    }
    @media (max-width: 600px) {
      .compare-grid { grid-template-columns: 1fr; }
    }
    .text-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 14px 16px;
    }
    .text-box-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-bottom: 8px;
    }
    .text-box-label.orig { color: var(--muted); }
    .text-box-label.corr { color: var(--green); }
    .text-box p {
      font-size: 0.92rem;
      line-height: 1.65;
      color: var(--text);
    }

    /* Copy button */
    .copy-btn {
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--muted);
      padding: 6px 14px;
      border-radius: 8px;
      font-size: 0.78rem;
      font-family: 'Sora', sans-serif;
      cursor: pointer;
      transition: all 0.2s;
      margin-top: 8px;
    }
    .copy-btn:hover { border-color: var(--accent); color: var(--accent); }

    /* Changes list */
    .changes-section { margin-bottom: 16px; }
    .changes-title {
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .change-item {
      display: flex;
      align-items: flex-start;
      gap: 8px;
      padding: 8px 12px;
      background: var(--surface);
      border-radius: 8px;
      font-size: 0.84rem;
      line-height: 1.5;
      margin-bottom: 6px;
      border-left: 3px solid var(--accent);
    }
    .change-item::before { content: "→"; color: var(--accent); flex-shrink: 0; }

    /* Explanation */
    .explanation-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent2);
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--text);
    }
    .explanation-label {
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      color: var(--accent2);
      margin-bottom: 6px;
    }

    /* Error */
    #error {
      display: none;
      background: rgba(248,113,113,0.08);
      border: 1px solid rgba(248,113,113,0.3);
      border-radius: 10px;
      padding: 14px 16px;
      font-size: 0.88rem;
      color: var(--red);
    }

    /* Examples */
    .examples-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }
    .example-chip {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 5px 14px;
      font-size: 0.78rem;
      color: var(--muted);
      cursor: pointer;
      transition: all 0.2s;
    }
    .example-chip:hover {
      border-color: var(--accent);
      color: var(--accent);
    }
  </style>
</head>
<body>

<header>
  <div class="logo">✦</div>
  <div>
    <h1>GrammarHelpBot <span>by Kudsia Khan</span></h1>
  </div>
  <div class="lang-badges">
    <span class="badge de">DE</span>
    <span class="badge en">EN</span>
    <span class="badge ur">UR</span>
  </div>
</header>

<main>
  <p class="tagline">
    <strong>Grammatik verbessern · Grammar fix · Grammar theek karo</strong><br/>
    Schreib einfach deinen Text — der Bot erkennt die Sprache automatisch und korrigiert ihn menschlich &amp; natürlich.
  </p>

  <!-- Input -->
  <div class="card">
    <div class="card-label">Dein Text / Your text / Apka text</div>
    <textarea id="inputText" placeholder="z.B.: ich bin gestern in den kino gegangen und der film war sehr gut...&#10;e.g.: yesterday i go to cinema and the movie was very nice...&#10;e.g.: kal mujhe uske saath milna tha lekin wo nahi aaye..."></textarea>
    <div class="input-footer">
      <span id="charCount">0 / 2000</span>
      <button id="submitBtn" onclick="correctText()">✦ Korrigieren</button>
    </div>
  </div>

  <!-- Example chips -->
  <div class="card" style="padding:16px 24px;">
    <div class="card-label" style="margin-bottom:10px;">Beispiele / Examples / Misalein</div>
    <div class="examples-row">
      <span class="example-chip" onclick="setExample('ich hab gestern das film gesehen und er war sehr schön und aufregend')">🇩🇪 Deutsch</span>
      <span class="example-chip" onclick="setExample('yesterday i go to the market and buyed many things for my family')">🇬🇧 English</span>
      <span class="example-chip" onclick="setExample('kal main market gaya aur bohot cheezain kharida apne ghar ke liye')">🇵🇰 Roman Urdu</span>
      <span class="example-chip" onclick="setExample('wir hat heute morgen ein wichtig treffen gehabt mit unserem chef')">🇩🇪 Fehler</span>
      <span class="example-chip" onclick="setExample('she don\'t know what to do so she just stay at home all the day')">🇬🇧 Errors</span>
    </div>
  </div>

  <!-- Loading -->
  <div id="loading">
    <div class="spinner"></div>
    Analysiere Text...
  </div>

  <!-- Error -->
  <div id="error"></div>

  <!-- Result -->
  <div id="result" class="card">
    <div class="result-header">
      <div class="status-dot" id="statusDot"></div>
      <div class="result-title" id="resultTitle"></div>
      <div class="detected-lang" id="detectedLang"></div>
    </div>

    <div class="compare-grid">
      <div class="text-box">
        <div class="text-box-label orig">Original</div>
        <p id="origText"></p>
      </div>
      <div class="text-box">
        <div class="text-box-label corr">Korrigiert / Corrected</div>
        <p id="corrText"></p>
        <button class="copy-btn" onclick="copyResult()">📋 Kopieren</button>
      </div>
    </div>

    <div class="changes-section" id="changesSection">
      <div class="changes-title">Änderungen / Changes</div>
      <div id="changesList"></div>
    </div>

    <div>
      <div class="explanation-label">Erklärung / Explanation</div>
      <div class="explanation-box" id="explanationText"></div>
    </div>
  </div>
</main>

<script>
  const textarea = document.getElementById('inputText');
  const charCount = document.getElementById('charCount');

  textarea.addEventListener('input', () => {
    const len = textarea.value.length;
    charCount.textContent = `${len} / 2000`;
    charCount.className = len > 1800 ? 'over' : len > 1500 ? 'warn' : '';
  });

  function setExample(text) {
    textarea.value = text;
    textarea.dispatchEvent(new Event('input'));
    textarea.focus();
  }

  async function correctText() {
    const text = textarea.value.trim();
    if (!text) return;
    if (text.length > 2000) {
      showError('Text ist zu lang (max. 2000 Zeichen).');
      return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    document.getElementById('loading').style.display = 'block';
    document.getElementById('result').style.display = 'none';
    document.getElementById('error').style.display = 'none';

    try {
      const res = await fetch('/correct', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text })
      });
      const data = await res.json();

      if (data.error) { showError(data.error); return; }

      renderResult(data);
    } catch (e) {
      showError('Verbindungsfehler. Bitte nochmal versuchen.');
    } finally {
      btn.disabled = false;
      document.getElementById('loading').style.display = 'none';
    }
  }

  function renderResult(data) {
    const dot   = document.getElementById('statusDot');
    const title = document.getElementById('resultTitle');
    const lang  = document.getElementById('detectedLang');

    if (data.was_correct) {
      dot.className   = 'status-dot ok';
      title.textContent = '✓ Alles korrekt! / All correct! / Sab theek hai!';
    } else {
      dot.className   = 'status-dot fixed';
      title.textContent = '✦ Text verbessert / Text improved / Text behtar kiya';
    }

    const langMap = { 'German': '🇩🇪 Deutsch', 'English': '🇬🇧 English', 'Roman Urdu': '🇵🇰 Roman Urdu' };
    lang.textContent = langMap[data.detected_language] || data.detected_language;

    document.getElementById('origText').textContent = data.original;
    document.getElementById('corrText').textContent = data.corrected;

    const changesSection = document.getElementById('changesSection');
    const changesList    = document.getElementById('changesList');
    changesList.innerHTML = '';

    if (data.changes && data.changes.length > 0) {
      data.changes.forEach(c => {
        const div = document.createElement('div');
        div.className = 'change-item';
        div.textContent = c;
        changesList.appendChild(div);
      });
      changesSection.style.display = 'block';
    } else {
      changesSection.style.display = 'none';
    }

    document.getElementById('explanationText').textContent = data.explanation;
    document.getElementById('result').style.display = 'block';
    document.getElementById('result').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function showError(msg) {
    const el = document.getElementById('error');
    el.textContent = '⚠ ' + msg;
    el.style.display = 'block';
    document.getElementById('loading').style.display = 'none';
    document.getElementById('submitBtn').disabled = false;
  }

  async function copyResult() {
    const text = document.getElementById('corrText').textContent;
    await navigator.clipboard.writeText(text);
    const btn = event.target;
    btn.textContent = '✓ Kopiert!';
    setTimeout(() => btn.textContent = '📋 Kopieren', 1500);
  }

  // Enter shortcut (Ctrl+Enter)
  textarea.addEventListener('keydown', e => {
    if (e.ctrlKey && e.key === 'Enter') correctText();
  });
</script>
</body>
</html>
